<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Tasks</h2>
    <a href="/tasks/create" class="btn btn-primary">+ Create New Task</a>
</div>

<% if (tasks.length === 0) { %>
    <div class="alert alert-info">
        No tasks yet. Click the button above to create your first task!
    </div>
<% } else { %>
    <div class="row">
        <% tasks.forEach(task => { %>
            <div class="col-md-6 col-lg-4 mb-3">
                <div class="card task-item">
                    <div class="card-body">
                        <h5 class="card-title d-flex justify-content-between align-items-center">
                            <%= task.title %>
                            <% if (task.status === 'completed') { %>
                                <span class="badge badge-completed"> Completed</span>
                            <% } else { %>
                                <span class="badge badge-pending"> Pending</span>
                            <% } %>
                           
                        </h5>
                        <p class="card-text"><%= task.description || 'No description provided' %></p>
                        <p class="card-text">
                            <small class="text-muted">
                                Created: <%= new Date(task.created_at).toLocaleDateString() %>
                                <% if (task.username) { %>
                                    <br>Assigned to: <%= task.username %>
                                <% } %>
                            </small>
                        </p>
                        <div class="btn-group">
                            <a href="/tasks/edit/<%= task.id %>" >
                                <button type="submit" class="btn btn-sm btn-warning">Edit</button>
                            </a>&nbsp;&nbsp;
                            <form method="POST" action="/tasks/delete/<%= task.id %>" class="delete-task-btn"
                                  style="display: inline;" 
                                  >
                                  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                                <button type="submit" 
                                class="btn btn-sm btn-danger" 
                                >
                                Delete
                            </button>
                            </form>
                           
                        </div>
                    </div>
                </div>
            </div>
        <% }) %>
    </div>
<% } %>

<%- include('../partials/footer') %>
